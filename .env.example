# ===== Puculuxa — Variáveis de Ambiente =====
# Copie este ficheiro para .env e preencha os valores reais

# ------------------------------------------------
# BACKEND
# ------------------------------------------------

# Porta do servidor NestJS (padrão: 3001)
PORT=3001

# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Segredo para assinar JWTs (use uma string longa e aleatória em prod)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# Expiração dos tokens de acesso
JWT_EXPIRY=7d

# ------------------------------------------------
# BASE DE DADOS
# ------------------------------------------------

# SQLite (desenvolvimento local)
DATABASE_URL="file:./prisma/dev.db"

# Para produção com PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/puculuxa_db"

# ------------------------------------------------
# REDIS (cache + BullMQ)
# ------------------------------------------------

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ------------------------------------------------
# UPLOADS / STORAGE
# ------------------------------------------------

# Diretório local para uploads de imagens
UPLOAD_DIR=./uploads

# Tamanho máximo de ficheiro em bytes (padrão: 5MB)
MAX_FILE_SIZE=5242880

# ------------------------------------------------
# NOTIFICAÇÕES (opcional)
# ------------------------------------------------

# WhatsApp número para notificações de orçamento
# WHATSAPP_PHONE=+244923000000

# ------------------------------------------------
# APLICAÇÃO WEB (Next.js)
# ------------------------------------------------

# URL base da API (sem trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ------------------------------------------------
# APLICAÇÃO MOBILE (Expo)
# ------------------------------------------------

# URL base da API para o app mobile
# Ao usar Expo Go no dispositivo físico, use o IP da sua máquina:
# EXPO_PUBLIC_API_URL=http://192.168.1.X:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
