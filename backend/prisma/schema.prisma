// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?   // null for "on request"
  category    String
  image       String?
  tags        String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
  reviews     Review[]

  @@index([category])
  @@index([createdAt])
}

model Quotation {
  id            String   @id @default(cuid())
  eventType     String
  guestCount    Int
  eventDate     DateTime?
  total         Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  customerName  String?
  customerPhone String?
  customerId    String?
  customer      User?    @relation(fields: [customerId], references: [id])
  referenceImage String?
  rejectionReason String?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  password   String
  name       String?
  phone      String?
  role       String      @default("CUSTOMER") // CUSTOMER, ADMIN
  avatarUrl  String?
  address    String?
  city       String?
  resetToken   String?
  refreshToken String?
  deletedAt    DateTime?
  quotations   Quotation[]
  orders       Order[]
  feedbacks    Feedback[]
  reviews      Review[]
  loyalty      LoyaltyPoints?
  messages     ChatMessage[]
  createdAt  DateTime    @default(now())

  @@index([role])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  total     Float
  status    String      @default("PENDING") // PENDING, COMPLETED, CANCELLED
  feedback  Feedback?
  payments  Payment[]
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String  // Snapshot of product name
  price     Float   // Snapshot of price at time of order
  quantity  Int

  @@index([orderId])
  @@index([productId])
}

model Feedback {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      // 1-5
  comment   String?
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([rating])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  sender    String   @default("CUSTOMER") // "CUSTOMER" ou "ADMIN"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  amount        Float
  method        String   // MULTICAIXA, TRANSFER, CASH
  status        String   @default("PENDING") // PENDING, PAID, FAILED
  receiptUrl    String?
  transactionId String?
  createdAt     DateTime @default(now())
  
  @@index([orderId])
}

model LoyaltyPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  tier      String   @default("BRONZE") // BRONZE, SILVER, GOLD
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([userId])
}

