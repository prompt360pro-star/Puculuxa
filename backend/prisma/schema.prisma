// Puculuxa — Prisma Schema v3.1
// Sistema de Pedidos Personalizados Inteligentes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// FINANCIAL ENUMS (FASE 9A)
// ─────────────────────────────────────────────
enum PaymentMethod {
  APPYPAY_GPO
  APPYPAY_REF
  BANK_TRANSFER
  GOVERNMENT_CREDIT
  CASH
}

enum FollowUpChannel {
  PHONE
  EMAIL
  WHATSAPP
  IN_PERSON
  DOCUMENT
  OTHER
}

enum FollowUpOutcome {
  NO_RESPONSE
  PROMISED_PAYMENT
  REQUESTED_DOCUMENTS
  SENT_TO_TREASURY
  ORDER_OF_WITHDRAWAL_PENDING
  PAID_CONFIRMED
  OTHER
}

enum WhatsAppMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  SKIPPED
}

enum PaymentStatus {
  PENDING
  AWAITING_PROOF
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum FinancialStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  IN_CREDIT
  OVERDUE
}

enum ReminderChannel {
  PUSH
  EMAIL
  WHATSAPP
  INTERNAL
}

enum PaymentReminderType {
  PAYMENT_PENDING_GPO
  PAYMENT_AWAITING_PROOF
  PAYMENT_AWAITING_VALIDATION
  CREDIT_DUE_SOON
  CREDIT_OVERDUE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum ClientSegment {
  B2C
  B2B
  GOVERNMENT
}

enum PayoutProvider {
  APPYPAY
}

enum PayoutStatus {
  DRAFT // criado internamente, ainda não conciliado
  REPORTED // lançado manualmente com valores do portal AppyPay
  PAID // confirmado no banco (BAI)
  DISCREPANCY // há diferença entre gross/fees/net vs soma dos items
  CANCELLED
}

enum PayoutSource {
  MANUAL
  API
}

// ─────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────
model Product {
  id              String          @id @default(cuid())
  name            String
  description     String?
  price           Float? // null = "sob consulta"
  category        String
  image           String?
  tags            String?
  servings        Int? // porções por unidade
  prepTimeDays    Int? // dias de preparação
  suggestedEvents String? // JSON: ["casamento","aniversario"]
  popularityScore Int             @default(0)
  complexityBase  Int             @default(1) // 1-5
  deletedAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  orderItems      OrderItem[]
  quotationItems  QuotationItem[]
  reviews         Review[]

  @@index([category])
  @@index([createdAt])
  @@index([popularityScore])
}

// ─────────────────────────────────────────────
// QUOTATION (expandido v3.1)
// ─────────────────────────────────────────────
model Quotation {
  id              String    @id @default(cuid())
  eventType       String
  guestCount      Int
  eventDate       DateTime?
  description     String? // "bolo unicórnio 3 andares"
  referenceImage  String?
  complexityScore Int? // 1-5 calculado
  source          String    @default("APP") // APP | WHATSAPP_IMPORT | ADMIN_CREATED | INSTAGRAM
  // Status: DRAFT | SUBMITTED | IN_REVIEW | PROPOSAL_SENT | NEGOTIATING | ACCEPTED | REJECTED | EXPIRED | CONVERTED
  status          String    @default("SUBMITTED")
  estimatedTotal  Float // cálculo automático inicial
  notes           String? // notas internas admin

  // SLA
  slaDeadline DateTime?
  escalatedAt DateTime?

  // Conversão
  convertedOrderId String?

  // Cliente
  customerName  String?
  customerPhone String?
  customerId    String?
  customer      User?   @relation(fields: [customerId], references: [id])

  // Relações
  versions    QuotationVersion[]
  complements QuotationComplement[]
  items       QuotationItem[]
  auditLog    StatusAuditLog[]
  convertedOrder Order?

  rejectionReason String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([slaDeadline])
}

// ─────────────────────────────────────────────
// QUOTATION VERSION (proposta v1, v2, v3...)
// ─────────────────────────────────────────────
model QuotationVersion {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  version     Int
  price       Float
  response    String? // mensagem ao cliente
  changedBy   String // ADMIN | CUSTOMER
  changes     String? // resumo da alteração
  // Status: PENDING | ACCEPTED | SUPERSEDED
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

// ─────────────────────────────────────────────
// QUOTATION COMPLEMENT (relacional, não JSON)
// ─────────────────────────────────────────────
model QuotationComplement {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  name        String // "Cupcakes Decorados"
  type        String // PER_UNIT | PER_GUEST | FIXED
  unitPrice   Float
  quantity    Int       @default(1)
  subtotal    Float
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

// ─────────────────────────────────────────────
// QUOTATION ITEM (liga Quotation → Product)
// ─────────────────────────────────────────────
model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id])
  name        String
  price       Float
  quantity    Int
  createdAt   DateTime  @default(now())

  @@index([quotationId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────
// STATUS AUDIT LOG (auditoria de transições de cotação)
// ─────────────────────────────────────────────────────
model StatusAuditLog {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  fromStatus  String
  toStatus    String
  changedBy   String // userId ou "SYSTEM"
  reason      String?
  createdAt   DateTime  @default(now())

  @@index([quotationId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// KITCHEN CAPACITY (capacidade diária)
// ─────────────────────────────────────────────
model KitchenCapacity {
  id           String   @id @default(cuid())
  date         DateTime @unique
  maxOrders    Int      @default(5)
  bookedOrders Int      @default(0)
  // load = bookedOrders / maxOrders
  createdAt    DateTime @default(now())

  @@index([date])
}

// ─────────────────────────────────────────────
// SLA CONFIG (SLA por tipo de evento)
// ─────────────────────────────────────────────
model SlaConfig {
  id            String @id @default(cuid())
  eventType     String @unique
  deadlineHours Int    @default(2)
  businessStart Int    @default(8) // 08:00
  businessEnd   Int    @default(20) // 20:00
}

// ─────────────────────────────────────────────
// EVENT REMINDER (motor de recompra)
// ─────────────────────────────────────────────
model EventReminder {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  eventName     String // "Aniversário da Sofia"
  eventType     String
  eventDate     DateTime
  nextReminder  DateTime
  status        String   @default("PENDING") // PENDING | SENT_30D | SENT_7D | SENT_3D | COMPLETED
  sourceOrderId String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([nextReminder])
  @@index([status])
}

// ─────────────────────────────────────────────
// USER (expandido com EventReminder)
// ─────────────────────────────────────────────
model User {
  id           String          @id @default(cuid())
  email        String          @unique
  password     String
  name         String?
  phone        String?
  role         String          @default("CUSTOMER") // CUSTOMER, ADMIN
  avatarUrl    String?
  address      String?
  city         String?
  resetToken   String?
  refreshToken String?
  pushToken    String? // Expo push token for mobile notifications
  deletedAt    DateTime?
  quotations   Quotation[]
  orders       Order[]
  feedbacks    Feedback[]
  reviews      Review[]
  loyalty      LoyaltyPoints?
  messages     ChatMessage[]
  reminders    EventReminder[]
  createdAt    DateTime        @default(now())

  @@index([role])
}

// ─────────────────────────────────────────────
// ORDER (FASE 9A — camada financeira)
// ─────────────────────────────────────────────
model Order {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  items           OrderItem[]
  total           Float
  status          String          @default("PENDING")
  financialStatus FinancialStatus @default(UNPAID)
  paymentMode     PaymentMethod?
  feedback        Feedback?
  payments        Payment[]
  invoices        Invoice[]
  deletedAt       DateTime?

  // Histórico de Conversão
  convertedFromId String?   @unique
  quotation       Quotation? @relation(fields: [convertedFromId], references: [id])

  // ─── Campos de Crédito Institucional (FASE 9D) ───
  creditDueDate         DateTime? // prazo acordado para pagamento
  creditApprovedAt      DateTime?
  creditApprovedById    String? // admin userId que aprovou
  creditNotes           String? // observações livres
  debtorEntityName      String? // ex: Ministério da Educação
  debtorEntityNif       String? // NIF da entidade
  debtorProcessRef      String? // ex: Proc. nº 2026/MINEA/0042
  lastPaymentFollowUpAt DateTime? // data do último follow-up

  // Termos Financeiros e Configurações de Pagamento (Snapshots 11C)
  clientSegment         ClientSegment @default(B2C)
  depositPercentApplied Int?         // Ex: 50%
  depositAmount         Float?       // valor do sinal (total * percent)
  depositDueDate        DateTime?    // prazo limite para pagar o sinal
  balanceDueDate        DateTime?    // prazo limite para liquidar o resto
  termsAppliedAt        DateTime?    // quando os termos foram congelados neste Order
  termsAppliedById      String?      // admin que forçou/aplicou (se manual)

  followUpLogs          PaymentFollowUpLog[]
  whatsappLogs          WhatsAppLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@index([financialStatus])
  @@index([creditDueDate])
  @@index([paymentMode])
  @@index([clientSegment])
  @@index([depositDueDate])
  @@index([balanceDueDate])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Float
  quantity  Int

  @@index([orderId])
  @@index([productId])
}

// ─────────────────────────────────────────────
// FEEDBACK, CHAT, REVIEW, PAYMENT, LOYALTY
// ─────────────────────────────────────────────
model Feedback {
  id         String    @id @default(cuid())
  orderId    String    @unique
  order      Order     @relation(fields: [orderId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  rating     Int // 1-5
  comment    String?
  adminReply String?
  repliedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([rating])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  text      String
  sender    String   @default("CUSTOMER")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PAYMENT (FASE 9A — expandido)
// ─────────────────────────────────────────────
model Payment {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id])
  amount         Float
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  providerRef    String?       @unique // ref do gateway (AppyPay)
  merchantRef    String?       @unique // ref interna Puculuxa
  idempotencyKey String?       @unique // previne duplicação de webhook
  proofUrl       String? // comprovativo de transferência
  metadata       Json? // dados extra do gateway
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  payoutItem     PayoutItem?

  @@index([orderId])
  @@index([status])
}

// ─────────────────────────────────────────────
// PAYOUT (FASE 11A — Tracking Settlement/AppyPay)
// ─────────────────────────────────────────────
model Payout {
  id       String         @id @default(cuid())
  provider PayoutProvider @default(APPYPAY)
  source   PayoutSource   @default(MANUAL)
  status   PayoutStatus   @default(DRAFT)

  // Identificador do payout/settlement no provider (se existir)
  providerPayoutRef String? @unique

  currency String @default("AOA")

  // Totais do settlement
  grossAmount Float @default(0) // soma payments brutos incluídos
  feeAmount   Float @default(0) // comissão do gateway
  netAmount   Float @default(0) // gross - fee (ou valor liquidado)

  // Janela de settlement (útil para auditoria)
  periodStart DateTime?
  periodEnd   DateTime?

  // Conciliação bancária (BAI)
  bankName      String? // default "Banco BAI"
  bankIban      String? // default IBAN Puculuxa
  bankReference String? // referência do depósito/transferência no extrato
  valueDate     DateTime? // data-valor no banco
  statementUrl  String? // opcional: upload do comprovativo/extrato

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PayoutItem[]

  @@index([status])
  @@index([provider])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([valueDate])
}

model PayoutItem {
  id        String   @id @default(cuid())
  payoutId  String
  payout    Payout   @relation(fields: [payoutId], references: [id])
  paymentId String   @unique
  // O tipo do Payment referenciado aqui evita que a tabela de Payment suje com colunas extras
  payment   Payment  @relation(fields: [paymentId], references: [id])
  amount    Float
  createdAt DateTime @default(now())

  @@index([payoutId])
}

// ─────────────────────────────────────────────
// PAYMENT REMINDER LOG (FASE 10D)
// ─────────────────────────────────────────────
model PaymentReminderLog {
  id        String              @id @default(cuid())
  type      PaymentReminderType
  channel   ReminderChannel     @default(PUSH)
  orderId   String?
  paymentId String?
  userId    String? // customer userId se aplicável
  target    String? // ex: phone/email se necessário
  sentAt    DateTime            @default(now())
  meta      Json?

  @@index([type])
  @@index([orderId])
  @@index([paymentId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// INVOICE (FASE 9C-1 — numeração configurável AGT)
// ─────────────────────────────────────────────
model Invoice {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id])
  invoiceNumber  String    @unique
  prefix         String? // ex: PF, FT, NE
  year           Int? // ex: 2025
  sequenceNumber Int? // ex: 347
  totalAmount    Float
  issuedAt       DateTime  @default(now())
  dueDate        DateTime?
  isGovernment   Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([orderId])
}

// ─────────────────────────────────────────────
// INVOICE CONFIG (FASE 9C-1 — config de série/numeração)
// ─────────────────────────────────────────────
model InvoiceConfig {
  id         String   @id @default(cuid())
  prefix     String   @default("PF") // PF=Pró-forma, FT=Fatura, NE=Nota Encomenda
  year       Int
  nextNumber Int      @default(1)
  padding    Int      @default(5) // 00001
  format     String   @default("{prefix} {year}/{number}")
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([prefix, year])
}

model LoyaltyPoints {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  points    Int      @default(0)
  tier      String   @default("BRONZE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─────────────────────────────────────────────
// PAYMENT FOLLOW-UP LOG (FASE 11D)
// ─────────────────────────────────────────────

model PaymentFollowUpLog {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id])
  createdById    String
  channel        FollowUpChannel @default(PHONE)
  outcome        FollowUpOutcome @default(OTHER)
  note           String          @db.Text
  nextFollowUpAt DateTime?
  attachmentUrl  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([orderId])
  @@index([createdAt])
  @@index([nextFollowUpAt])
  @@map("payment_followup_logs")
}

// ─────────────────────────────────────────────
// WHATSAPP API LOGGING (FASE 12A)
// ─────────────────────────────────────────────
model WhatsAppLog {
  id              String                @id @default(cuid())

  // Contexto para auditoria
  orderId         String?
  order           Order?                @relation(fields: [orderId], references: [id])

  recipientPhone  String
  templateName    String
  languageCode    String                @default("pt_PT")

  status          WhatsAppMessageStatus @default(PENDING)

  // IDs Meta Graph
  waMessageId     String?               @unique // wamid.xxx
  conversationId  String?
  webhookStatusRaw Json?

  // Anti-spam/idempotência
  idempotencyKey  String?               @unique

  // Payload para retry real
  variables       Json?

  errorMessage    String?

  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([orderId])
  @@index([recipientPhone])
  @@index([templateName])
  @@index([status])
  @@index([createdAt])
  @@map("whatsapp_logs")
}
